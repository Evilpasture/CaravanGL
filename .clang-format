---
Language: Cpp
BasedOnStyle: LLVM

# --- Space to Breathe ---
IndentWidth: 4
ContinuationIndentWidth: 4
ColumnLimit: 100
UseTab: Never
Standard: Latest

# --- Macro Guard ---
# This ensures your custom DSL-like macros don't get mangled
StatementMacros: 
  - ImportCaravanGL
  - WITH_CARAVAN_GL
  - CARAVAN_GL_SCOPE
  - WithCaravanGL

# --- Braces & Logic ---
BreakBeforeBraces: Attach
AllowShortIfStatementsOnASingleLine: WithoutElse
AllowShortLoopsOnASingleLine: false

# --- Alignment & Cleanliness ---
AlignAfterOpenBracket: Align
AlignTrailingComments: true
SpaceAfterCStyleCast: false

# --- Include Sorting (Python First!) ---
IncludeCategories:
  - Regex: '^<Python\.h>'
    Priority: -1
  - Regex: '^"caravan_'
    Priority: 1
  - Regex: '.*'
    Priority: 2
...