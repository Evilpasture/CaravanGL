# CaravanGL Clang-Tidy Configuration
# Targets C23 and High-Performance Systems Programming

Checks: >
  -*,
  bugprone-*,
  clang-analyzer-*,
  performance-*,
  readability-*,
  modernize-use-nullptr,
  modernize-use-bool-literals,
  cert-*,
  
  # Structural & Hardware-Sympathetic Suppressions
  -altera-struct-pack-align,
  -altera-id-dependent-backward-branch,
  
  # Environment & Toolchain Suppressions
  -llvm-libc-restrict-system-headers,
  -llvm-libc-implementation-in-namespace,
  
  # Style & Noise Reduction
  -readability-identifier-naming,
  -readability-braces-around-statements,
  -readability-function-size,
  -readability-redundant-declaration,
  -readability-function-cognitive-complexity,
  
  # Systems Programming Essentials
  -bugprone-reserved-identifier,
  -bugprone-macro-parentheses,
  -bugprone-easily-swappable-parameters,
  -clang-analyzer-security.insecureAPI.DeprecatedOrUnsafeBufferPointer

# Fail the build for critical logic errors
WarningsAsErrors: >
  bugprone-*,
  performance-*,
  concurrency-*,
  clang-analyzer-*

HeaderFilterRegex: '^(?!.*extern/).*(include/|src/).*'

CheckOptions:
  # C23 nullptr is the gold standard; treat NULL as an alias
  - key:             modernize-use-nullptr.NullMacros
    value:           'NULL,nullptr,PY_SSIZE_T_CLEAN'

  # Python's headers are full of int-to-ptr casts; ignore them globally
  - key:             performance-no-int-to-ptr.IgnoreDirectories
    value:           'Python;include/python3.14t'

  # Standard MT-unsafe functions to watch out for
  - key:             concurrency-mt-unsafe.FunctionNames
    value:           'setenv,getenv,strtok'